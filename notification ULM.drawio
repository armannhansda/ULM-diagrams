        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n  class NotificationService {\n    -instance\n    -strategy\n    +getInstance()\n    +setStrategy()\n    +sendNotification()\n  }\n  class NotificationStrategy {\n    &lt;&lt;abstract&gt;&gt;\n    +send(Notification)\n  }\n  class EmailStrategy {\n    +send()\n  }\n  class SMSStrategy {\n    +send()\n  }\n  class PushStrategy {\n    +send()\n  }\n  NotificationService --&gt; NotificationStrategy\n  NotificationStrategy &lt;|-- EmailStrategy\n  NotificationStrategy &lt;|-- SMSStrategy\n  NotificationStrategy &lt;|-- PushStrategy\n\n  class Notification {\n    &lt;&lt;abstract&gt;&gt;\n    +getContent() string\n  }\n  class SimpleNotification {\n    -text\n    +getContent()\n  }\n  class NotificationDecorator {\n    #notification : Notification\n    +getContent()\n  }\n  class TimestampDeco {\n    +getContent()\n  }\n  class SignatureDeco {\n    +getContent()\n  }\n  class EncryptionDeco {\n    +getContent()\n  }\n  Notification &lt;|-- SimpleNotification\n  Notification &lt;|-- NotificationDecorator\n  NotificationDecorator o-- Notification\n  NotificationDecorator &lt;|-- TimestampDeco\n  NotificationDecorator &lt;|-- SignatureDeco\n  NotificationDecorator &lt;|-- EncryptionDeco\n\n  class Observable {\n    &lt;&lt;abstract&gt;&gt;\n    +addObserver()\n    +removeObserver()\n    +notifyObservers()\n  }\n  class NotificationObservable {\n    -observers : List\n    -notification\n    +setNotification()\n    +getNotification()\n    +notifyObservers()\n  }\n  class Observer {\n    &lt;&lt;abstract&gt;&gt;\n    +update()\n  }\n  class LoggerObserver {\n    +update()\n  }\n  class DatabaseObs {\n    +update()\n  }\n  class AnalyticsObserver {\n    +update()\n  }\n  Observable &lt;|-- NotificationObservable\n  Observer &lt;|-- LoggerObserver\n  Observer &lt;|-- DatabaseObs\n  Observer &lt;|-- AnalyticsObserver\n  NotificationObservable --&gt; Observer : notifies&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="95ljqdtogvRGpSAPRX8R-1">
